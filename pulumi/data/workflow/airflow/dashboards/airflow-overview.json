          "refId": "A"
        },
        {
          "expr": "sum(airflow_triggers_running{namespace=\"airflow\"})",
          "legendFormat": "running triggers",
          "refId": "B"
        },
        {
          "expr": "sum(rate(airflow_triggerer_heartbeat{namespace=\"airflow\"}[5m])) * 60",
