        {
          "expr": "sum(airflow_executor_queued_tasks{namespace=\"airflow\"})",
          "legendFormat": "queued tasks",
          "refId": "B"
        },
        {
          "expr": "sum(airflow_executor_open_slots{namespace=\"airflow\"})",
          "legendFormat": "open slots",
          "refId": "C"
        }
      ],
      "title": "Executor Capacity",
      "type": "timeseries"
    },
