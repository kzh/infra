    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 12
      },
      "id": 8,
      "targets": [
        {
          "expr": "max(airflow_dag_processing_last_run_seconds_ago{namespace=\"airflow\"})",
          "legendFormat": "seconds since last parse loop",
          "refId": "A"
        },
        {
          "expr": "max(airflow_dag_processing_last_duration{namespace=\"airflow\"})",
          "legendFormat": "last parse duration",
          "refId": "B"
        },
        {
          "expr": "max(airflow_dag_processing_total_parse_time{namespace=\"airflow\"})",
          "legendFormat": "total parse time",
          "refId": "C"
        }
      ],
      "title": "DAG Processing",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 12
      },
      "id": 9,
      "targets": [
        {
          "expr": "sum(airflow_triggerer_capacity_left{namespace=\"airflow\"})",
