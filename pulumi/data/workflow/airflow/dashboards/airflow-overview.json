      "targets": [
        {
          "expr": "sum(airflow_dag_processing_import_errors{namespace=\"airflow\"})",
          "refId": "A"
        }
      ],
      "title": "Import Errors",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 5,
      "targets": [
        {
          "expr": "sum(airflow_executor_running_tasks{namespace=\"airflow\"})",
