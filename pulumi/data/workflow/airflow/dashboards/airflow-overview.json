        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 12
      },
      "id": 7,
      "targets": [
        {
          "expr": "sum(airflow_pool_running_slots{namespace=\"airflow\"})",
          "legendFormat": "running",
          "refId": "A"
        },
        {
          "expr": "sum(airflow_pool_queued_slots{namespace=\"airflow\"})",
          "legendFormat": "queued",
          "refId": "B"
        },
        {
          "expr": "sum(airflow_pool_open_slots{namespace=\"airflow\"})",
          "legendFormat": "open",
          "refId": "C"
        }
      ],
      "title": "Pool Slots",
      "type": "timeseries"
