        "h": 8,
        "w": 8,
        "x": 16,
        "y": 20
      },
      "id": 12,
      "targets": [
        {
          "expr": "sum by (pod, container) (increase(kube_pod_container_status_restarts_total{namespace=\"airflow\"}[6h]))",
          "legendFormat": "{{pod}} / {{container}}",
          "refId": "A"
        }
      ],
      "title": "Container Restarts Last 6h",
      "type": "timeseries"
    }
