set shell := ["bash", "-lc"]

arch := "linux/amd64"
repo := "ghcr.io/kzh"
spark_version := "4.1.1"
spark_java_version := "21"
iceberg_version := "1.10.1"
iceberg_spark_runtime := "4.0_2.13"
image := repo + "/spark:" + spark_version + "-iceberg" + iceberg_version + "-java" + spark_java_version

# Build locally for amd64.
build-image:
	docker buildx build --platform {{arch}} \
		-f images/spark-iceberg/Dockerfile \
		--build-arg SPARK_VERSION={{spark_version}} \
		--build-arg SPARK_JAVA_VERSION={{spark_java_version}} \
		--build-arg ICEBERG_VERSION={{iceberg_version}} \
		--build-arg ICEBERG_SPARK_RUNTIME={{iceberg_spark_runtime}} \
		-t {{image}} \
		--output=type=docker .

# Build and push the amd64 Spark image with the Iceberg runtime jar baked in.
push-image:
	docker buildx build --platform {{arch}} \
		-f images/spark-iceberg/Dockerfile \
		--build-arg SPARK_VERSION={{spark_version}} \
		--build-arg SPARK_JAVA_VERSION={{spark_java_version}} \
		--build-arg ICEBERG_VERSION={{iceberg_version}} \
		--build-arg ICEBERG_SPARK_RUNTIME={{iceberg_spark_runtime}} \
		-t {{image}} \
		--push .

inspect-image:
	docker buildx imagetools inspect {{image}}
